generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  requests  Request[]
}

model Request {
  id          Int           @id @default(autoincrement())
  mediaId     Int
  mediaType   MediaType
  mediaTitle  String
  mediaPoster String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  userId      Int
}

enum Role {
  USER
  ADMIN
}

enum MediaType {
  MOVIE
  TV
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}